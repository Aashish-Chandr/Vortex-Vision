# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=VortexVision
APP_VERSION=1.0.0
DEBUG=false
LOG_LEVEL=INFO

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP=localhost:9092
KAFKA_FRAMES_TOPIC=video-frames
KAFKA_ANNOTATED_TOPIC=annotated-frames
KAFKA_EVENTS_TOPIC=anomaly-events
KAFKA_CONSUMER_GROUP=detection-group

# ── Detection ─────────────────────────────────────────────────────────────────
YOLO_MODEL=yolo26n.pt
YOLO_DEVICE=cuda
YOLO_CONF=0.4
YOLO_IOU=0.5
FPS_LIMIT=30

# ── Anomaly ───────────────────────────────────────────────────────────────────
AE_THRESHOLD=0.05
TRANSFORMER_THRESHOLD=0.7
SEQ_LEN=16

# ── VLM ───────────────────────────────────────────────────────────────────────
VLM_MODE=api
VLM_MODEL=Qwen/Qwen2.5-VL-7B-Instruct
VLM_API_BASE=http://localhost:8080/v1
VLM_API_KEY=EMPTY
VLM_MAX_TOKENS=512

# ── Storage ───────────────────────────────────────────────────────────────────
CLIP_STORAGE_PATH=/data/clips
MODEL_STORAGE_PATH=/data/models
S3_BUCKET=vortexvision-data
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-key-id
AWS_SECRET_ACCESS_KEY=your-secret-key

# ── MLflow ────────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_EXPERIMENT=vortexvision

# ── Auth ──────────────────────────────────────────────────────────────────────
API_SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=120

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://vortex:vortex@postgres:5432/vortexvision

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379
